# =========================
# Global
# =========================
APP_NAME=lab-notebook
APP_ENV=dev

# =========================
# Web
# =========================
VITE_API_BASE_URL=http://localhost:8000/api

# =========================
# API
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# =========================
# Database
# =========================
POSTGRES_DB=lab_notebook
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lab_notebook

# =========================
# Storage
# =========================
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# =========================
# LLM
# Default mode is local. In development without a local model service,
# you can leave these empty and switch to API key mode from the frontend.
# =========================
LLM_PROVIDER=local
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
